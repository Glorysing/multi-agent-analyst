# ==========================================
# Multi-Agent Data Analyst - 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env
# ==========================================

# ---- 选择默认 Provider: ollama | anthropic | openai_compatible | groq ----
LLM_PROVIDER=ollama

# ---- Ollama 本地模型 (免费,离线,推荐演示时用) ----
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b          # 通用推理
OLLAMA_CODER_MODEL=qwen2.5-coder:7b  # Coder Agent 专用(代码能力更强)

# ---- Anthropic Claude (开发调试时用,效果最好) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- OpenAI 兼容 (DeepSeek / 硅基流动 / 千问 / Kimi / OpenAI 都走这里) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ---- Groq (免费额度, 在线 Demo 首选, https://console.groq.com/keys 免费注册) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Reviewer 最大迭代次数 ----
MAX_ITERATIONS=3

# ---- 输出语言: zh (简体中文) | en (English) ----
# 控制 agent prompt / 报告 / 图表标题 / SSE 状态文案的语言.
# 前端顶部切换 / CLI --lang / API body.language 会覆盖这个默认值.
OUTPUT_LANGUAGE=zh
